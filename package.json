{
  "name": "@kamranbiglari/pino-logger",
  "version": "1.0.0",
  "description": "Opinionated Pino wrapper for structured logging across Node.js services",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KamranBiglari/pino-logger.git"
  },
  "keywords": [
    "logger",
    "pino",
    "structured-logging",
    "typescript"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "pino-pretty": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "pino-pretty": {
      "optional": true
    }
  }
}
